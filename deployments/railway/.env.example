# OpenStatus Railway Environment Variables
# Copy this file and fill in your values

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# Database connection (Railway internal service)
DATABASE_URL=http://libsql:8080

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-character-secret-here-minimum

# Self-hosted mode (required for self-hosting)
SELF_HOST=true

# Environment
NODE_ENV=production

# Email Service (for magic link authentication)
# Get from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================================
# OPTIONAL OAUTH PROVIDERS
# ============================================================================

# GitHub OAuth (optional)
# Get from: https://github.com/settings/developers
AUTH_GITHUB_ID=your_github_oauth_client_id
AUTH_GITHUB_SECRET=your_github_oauth_client_secret

# Google OAuth (optional)
# Get from: https://console.cloud.google.com
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# ============================================================================
# OPTIONAL ANALYTICS
# ============================================================================

# Tinybird (optional - for analytics and charts)
# Leave empty to disable analytics features
# Get from: https://www.tinybird.co
TINY_BIRD_API_KEY=

# ============================================================================
# PLATFORM-SPECIFIC VARIABLES (Railway)
# ============================================================================

# Railway automatically sets PORT, but you can override if needed
# PORT=3000

# Public URLs (Railway automatically generates these)
# NEXT_PUBLIC_URL=https://your-service-production.up.railway.app

# ============================================================================
# OPTIONAL INTEGRATIONS
# ============================================================================

# Sentry (optional - error tracking)
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Stripe (optional - for payments)
# Get from: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Redis (optional - for caching)
# Railway provides managed Redis, or use external service
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# RAILWAY-SPECIFIC SETTINGS
# ============================================================================

# Railway project settings
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_NAME=openstatus

# Service names (for internal communication)
# LIBSQL_SERVICE_NAME=libsql
# DASHBOARD_SERVICE_NAME=dashboard
# STATUS_PAGE_SERVICE_NAME=status-page
# API_SERVICE_NAME=server
# WORKFLOWS_SERVICE_NAME=workflows

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable debug mode (not recommended for production)
DEBUG=false

# ============================================================================
# NOTES FOR RAILWAY DEPLOYMENT
# ============================================================================

# 1. Set environment variables in Railway project settings
# 2. Railway automatically creates volumes for database persistence
# 3. SSL certificates are automatically provisioned
# 4. Services communicate using Railway's internal DNS
# 5. Use service names (not URLs) for internal communication

# For full stack deployment, Railway will create these services:
# - libsql (database with persistent volume)
# - dashboard (web service)
# - status-page (web service)
# - server (API service)
# - workflows (background worker)

# For lightweight deployment, Railway will create:
# - libsql (database with persistent volume)
# - dashboard (web service)
# - status-page (web service)

# Railway-specific tips:
# - Use Railway's environment groups for different stages
# - Enable automatic deployments from GitHub
# - Monitor resource usage in Railway dashboard
# - Take advantage of Railway's free tier limits

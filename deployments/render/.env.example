# OpenStatus Render Environment Variables
# Copy this file and fill in your values

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-character-secret-here-minimum

# Email Service (for magic link authentication)
# Get from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Self-hosted mode (required for self-hosting)
SELF_HOST="true"

# ============================================================================
# OPTIONAL OAUTH PROVIDERS
# ============================================================================

# GitHub OAuth (optional)
# Get from: https://github.com/settings/developers
AUTH_GITHUB_ID=your_github_oauth_client_id
AUTH_GITHUB_SECRET=your_github_oauth_client_secret

# Google OAuth (optional)
# Get from: https://console.cloud.google.com
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# ============================================================================
# OPTIONAL ANALYTICS
# ============================================================================

# Tinybird (optional - for analytics and charts)
# Leave empty to disable analytics features
# Get from: https://www.tinybird.co
TINY_BIRD_API_KEY=

# ============================================================================
# PLATFORM-SPECIFIC VARIABLES (Render)
# ============================================================================

# Render automatically sets these, but you can override if needed
# PORT=3000
# NODE_ENV=production

# Public URLs (Render automatically sets these)
# NEXT_PUBLIC_URL=https://your-service.onrender.com

# ============================================================================
# OPTIONAL INTEGRATIONS
# ============================================================================

# Sentry (optional - error tracking)
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Stripe (optional - for payments)
# Get from: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Redis (optional - for caching)
# Render provides managed Redis, or use external service
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable debug mode (not recommended for production)
DEBUG=false

# ============================================================================
# NOTES FOR RENDER DEPLOYMENT
# ============================================================================

# 1. Render automatically provides PostgreSQL and Redis services
# 2. Database URLs will be automatically generated by Render
# 3. SSL certificates are automatically provisioned
# 4. Environment variables should be set in Render dashboard
# 5. Never commit actual secrets to this file

# For full stack deployment, Render will create these services:
# - openstatus-db (PostgreSQL)
# - openstatus-redis (Redis)
# - openstatus-api (private service)
# - openstatus-workflows (worker)
# - openstatus-dashboard (web service)
# - openstatus-status-page (web service)

# For lightweight deployment, Render will create:
# - openstatus-db (PostgreSQL)
# - openstatus-app (web service)
